# ─────────────────────────────────────────────────────────────
# CityFlow — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs.
# ⚠️  Ne commitez JAMAIS le fichier .env dans git.
# ─────────────────────────────────────────────────────────────

# ── Chemins (optionnel — valeurs par défaut si absent) ────────
# CITYFLOW_RAW_DIR=data/raw
# CITYFLOW_CLEAN_DIR=data/clean
# CITYFLOW_ARCHIVE_DIR=data/archive
# CITYFLOW_ERROR_DIR=data/errors
# CITYFLOW_DB_PATH=db/cityflow.db
# CITYFLOW_LOG_DIR=logs

# ── API Paris Open Data ───────────────────────────────────────
# CITYFLOW_OPEN_DATA_URL=https://opendata.paris.fr/api/explore/v2.1/catalog/datasets/comptages-routiers-permanents/records
# CITYFLOW_PAGE_SIZE=100

# ── API locale CityFlow ───────────────────────────────────────
# CITYFLOW_API_HOST=localhost
# CITYFLOW_API_PORT=8000

# Clés API — format : role:cle,role:cle
# ⚠️  Changez ces valeurs en production !
CITYFLOW_API_KEYS=viewer:VOTRE_CLE_VIEWER,admin:VOTRE_CLE_ADMIN

# Origines CORS autorisées (séparées par virgule)
CITYFLOW_CORS_ORIGINS=http://localhost:8501

# ── Règles de gouvernance (optionnel) ─────────────────────────
# CITYFLOW_MAX_DEBIT=10000
# CITYFLOW_MAX_K=100
# CITYFLOW_SEUIL_CONG_V=10
# CITYFLOW_SEUIL_RAL_V=25
# CITYFLOW_SEUIL_CONG_H=3
# CITYFLOW_SEUIL_RAL_H=1
# CITYFLOW_MIN_MESURES_HIGH=20
# CITYFLOW_MIN_MESURES_MEDIUM=5
# CITYFLOW_VERSION=1.0.0
